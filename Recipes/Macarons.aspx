<%@ Page Language="C#" MasterPageFile="~/all.Master" %>

<asp:Content ID="c1" ContentPlaceHolderID="TitleContent" runat="server">
    מקרונים – Ido Bakery & Pastry
</asp:Content>

<asp:Content ID="c2" ContentPlaceHolderID="PageHeader" runat="server">
    מקרונים
</asp:Content>

<asp:Content ID="c3" ContentPlaceHolderID="MainContent" runat="server">

    <div class="recipes-wrapper">

       
        <div class="recipe-box">
            <img src="/picture/lemon_cream_macarons.jpg" class="recipe-img" />

            <div class="recipe-text">
                <h3>מקרונים לימוניים קלאסיים</h3>

                <p><b>מרכיבים (קליפות):</b></p>
                <ul>
                    <li>200 גרם אבקת סוכר</li>
                    <li>110 גרם שקדים טחונים דק</li>
                    <li>90 גרם חלבוני ביצה</li>
                    <li>30 גרם סוכר לבן</li>
                    <li>גרידת לימון</li>
                </ul>

                <p><b>מרכיבים (מילוי):</b></p>
                <ul>
                    <li>100 גרם חמאה רכה</li>
                    <li>1/4 כוס אבקת סוכר</li>
                    <li>2–3 כפות מיץ לימון</li>
                </ul>

                <p><b>אופן הכנה:</b></p>
                <ol>
                    <li>מסננים אבקת סוכר ושקדים יחד.</li>
                    <li>מקציפים חלבונים ומוסיפים סוכר בהדרגה עד קצף יציב.</li>
                    <li>מקפלים את תערובת השקדים לתוך הקצף.</li>
                    <li>מזלפים עיגולים וממתינים 30 דקות ליצירת קרום.</li>
                    <li>אופים 140°C כ־15 דקות.</li>
                    <li>מקציפים חומרי מילוי וממלאים בין הקליפות.</li>
                </ol>
            </div>
        </div>

        <div class="recipe-box">
            <img src="/picture/tea_party_macarons..jpg" class="recipe-img" />

            <div class="recipe-text">
                <h3>מקרונים Tea Party לימוניים</h3>
                <p><b>מרכיבים:</b></p>
                <ul>
                    <li>200 גרם אבקת סוכר</li>
                    <li>110 גרם שקדים טחונים</li>
                    <li>90 גרם חלבוני ביצה</li>
                    <li>30 גרם סוכר</li>
                    <li>גרידת לימון</li>
                    <li>טיפה חליטת תה (אופציונלי)</li>
                </ul>

                <p><b>מרכיבים (מילוי):</b></p>
                <ul>
                    <li>100 גרם חמאה</li>
                    <li>1/4 כוס אבקת סוכר</li>
                    <li>2 כפות מיץ לימון</li>
                </ul>

                <p><b>אופן הכנה:</b></p>
                <ol>
                    <li>מסננים אבקת סוכר ושקדים.</li>
                    <li>מקציפים חלבונים עם סוכר.</li>
                    <li>מקפלים בעדינות ומזלפים.</li>
                    <li>ממתינים לייבוש הקרום.</li>
                    <li>אופים 140°C כ־15 דקות.</li>
                    <li>ממלאים בקרם לימון.</li>
                </ol>
            </div>
        </div>

       
        <div class="recipe-box">
            <img src="/picture/mako_macarons.jpg" class="recipe-img" />

            <div class="recipe-text">
                <h3>מקרונים שוקולדיים</h3>

                <p><b>מרכיבים:</b></p>
                <ul>
                    <li>200 גרם אבקת סוכר</li>
                    <li>100 גרם שקדים טחונים</li>
                    <li>10 גרם קקאו</li>
                    <li>90 גרם חלבוני ביצה</li>
                    <li>30 גרם סוכר</li>
                </ul>

                <p><b>מילוי גנאש:</b></p>
                <ul>
                    <li>100 גרם שוקולד מריר</li>
                    <li>100 מ״ל שמנת מתוקה</li>
                </ul>

                <p><b>אופן הכנה:</b></p>
                <ol>
                    <li>מסננים אבקת סוכר, שקדים וקקאו.</li>
                    <li>מקציפים חלבונים וסוכר.</li>
                    <li>מקפלים את היבשים.</li>
                    <li>מזלפים וממתינים 30 דקות.</li>
                    <li>אופים 140°C כ־15 דקות.</li>
                    <li>מחממים שמנת, שופכים על שוקולד, מקררים וממלאים.</li>
                </ol>
            </div>
        </div>

    </div>

</asp:Content>
